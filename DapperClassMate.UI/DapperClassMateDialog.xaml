<Window x:Class="DapperClassMate.UI.DapperClassMateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DapperClassMate.UI"
        xmlns:controls="clr-namespace:DapperClassMate.UI.Controls"
        mc:Ignorable="d"
        Title="Dapper ClassMate"
        Height="660"
        Width="1150"
        MinHeight="560"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" Icon="/DapperClassMate.UI;component/dapper_classmate.ico">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Dapper ClassMate"
                       FontSize="26"
                       FontWeight="SemiBold" />
            <TextBlock Text="Generate a request class, result POCO, and Dapper repository method."
                       Margin="0,4,0,0"
                       Foreground="Gray" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Connection String" />
                <Grid Margin="0,4,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ConnectionStringTextBox"
                             Grid.Column="0"
                             Height="28" Grid.ColumnSpan="3" Margin="0,0,83,0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>

                    <Button x:Name="BuildConnectionStringButton"
                            Grid.Column="2"
                            Content="Build..."
                            Height="28"
                            Click="BuildConnectionString_Click" Grid.ColumnSpan="3" Margin="12,0,116,0" />

                    <Button x:Name="LoadProceduresButton"
                            Grid.Column="4"
                            Content="Load Objects"
                            Height="28"
                            Click="LoadProcedures_Click" Margin="9,0,1,0" />
                </Grid>

                <TextBlock Text="Stored Procedure" />
                <ComboBox x:Name="StoredProcedureComboBox"
                          Height="28"
                          Margin="0,4,0,10"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          SelectedIndex="-1"
                          SelectionChanged="StoredProcedureComboBox_SelectionChanged" VerticalContentAlignment="Center" />

                <TextBlock Text="Table" />
                <ComboBox x:Name="TableComboBox"
                          Height="28"
                          Margin="0,4,0,10"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          SelectedIndex="-1"
                          SelectionChanged="TableComboBox_SelectionChanged" VerticalContentAlignment="Center"/>

                <TextBlock Text="View" />
                <ComboBox x:Name="ViewComboBox"
                          Height="28"
                          Margin="0,4,0,10"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          SelectedIndex="-1"
                          SelectionChanged="ViewComboBox_SelectionChanged" VerticalContentAlignment="Center" />

                <GroupBox Header="CRUD Operations"
                          Margin="0,2,0,0">
                    <StackPanel Margin="8"
                                Orientation="Horizontal">
                        <CheckBox x:Name="CreateCheckBox"
                                  Content="Create"
                                  IsEnabled="False"
                                  Margin="0,0,16,0" />
                        <CheckBox x:Name="ReadCheckBox"
                                  Content="Read"
                                  IsEnabled="False"
                                  Margin="0,0,16,0" />
                        <CheckBox x:Name="UpdateCheckBox"
                                  Content="Update"
                                  IsEnabled="False"
                                  Margin="0,0,16,0" />
                        <CheckBox x:Name="DeleteCheckBox"
                                  Content="Delete"
                                  IsEnabled="False" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Namespace" />
                <TextBox x:Name="NamespaceTextBox"
                         Height="28"
                         Margin="0,4,0,10" VerticalContentAlignment="Center" />

                <TextBlock Text="Repository Class Name" />
                <TextBox x:Name="RepositoryClassNameTextBox"
                         Height="28"
                         Margin="0,4,0,10"
                         VerticalContentAlignment="Center"
                         Text="GeneratedRepository" Background="{x:Null}" />

                <TextBlock Text="Connection Timeout (seconds)" />
                <controls:IntegerSpinEdit x:Name="CommandTimeoutSpinEdit"
                                          Margin="0,4,0,10"
                                          Minimum="1"
                                          Maximum="300"
                                          Increment="1"
                                          Value="30" />
                <TextBlock TextWrapping="Wrap" Text="Result Type"/>
                <ComboBox x:Name="MethodResultTypeComboBox" Height="28" IsTextSearchEnabled="True" IsEditable="True" SelectedIndex="-1" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="GenerateVBCode" VerticalContentAlignment="Center" Content="Generate VB Code" Margin="0,5,0,0" />
            </StackPanel>
        </Grid>

        <GroupBox Grid.Row="2"
                  Header="Preview"
                  Margin="0,0,0,14">
            <TextBox x:Name="PreviewTextBox"
                     Margin="8"
                     FontFamily="Consolas"
                     FontSize="13"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" />
        </GroupBox>
        <TextBlock x:Name="VersionNumber"
                   Grid.Row="3"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="3,0,0,0"
                   TextWrapping="Wrap"
                   Text="Version"
                   Foreground="Gray"
                   FontStyle="Italic" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="GenerateButton" Content="Generate"
                    Width="100"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="Generate_Click" />

            <Button x:Name="CopyButton" Content="Copy"
                    Width="80"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="Copy_Click" />

            <Button x:Name="CloseButton" Content="Close"
                    Width="80"
                    Height="30"
                    IsCancel="True"
                    Click="Close_Click" />
        </StackPanel>

    </Grid>
</Window>
