<Window x:Class="DapperClassMate.UI.ConnectionStringBuilderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Build SQL Connection String"
        Height="520"
        Width="620"
        MinHeight="420"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded" Icon="/DapperClassMate.UI;component/dapper_classmate.ico">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="SQL Server Connection"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Text="Build a connection string for Dapper ClassMate."
                       Margin="0,4,0,0"
                       Foreground="Gray" />
        </StackPanel>

        <!-- Server -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Server" VerticalAlignment="Center" />
            <ComboBox x:Name="ServerComboBox"
                      Grid.Column="1"
                      Height="28"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      SelectionChanged="ServerComboBox_SelectionChanged" VerticalContentAlignment="Center"
                      LostFocus="ServerComboBox_LostFocus" />
            <Button x:Name="RefreshServersButton"
                    Grid.Column="2"
                    Content="↺"
                    Width="30"
                    Height="28"
                    Margin="6,0,0,0"
                    ToolTip="Search for SQL Servers on the network"
                    Click="RefreshServers_Click" />
        </Grid>

        <!-- Database -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Database" VerticalAlignment="Center" />
            <ComboBox x:Name="DatabaseComboBox"
                      Grid.Column="1"
                      Height="28"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      IsEnabled="False"
                      SelectionChanged="DatabaseComboBox_SelectionChanged"
                      LostFocus="DatabaseComboBox_LostFocus" VerticalContentAlignment="Center" />
        </Grid>

        <!-- Windows Auth -->
        <CheckBox x:Name="IntegratedSecurityCheckBox"
                  Grid.Row="3"
                  Content="Use Windows Authentication"
                  Margin="150,0,0,10"
                  IsChecked="True"
                  Checked="IntegratedSecurityChanged"
                  Unchecked="IntegratedSecurityChanged" />

        <!-- Credentials -->
        <Grid x:Name="LoginCredentials" Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="141*" />
                <ColumnDefinition Width="293*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="UserIdLabel" Text="User ID" VerticalAlignment="Center" />
            <TextBox x:Name="UserIdTextBox"
                     Grid.Column="1"
                     Height="28"
                     TextChanged="Credentials_Changed" VerticalContentAlignment="Center" Grid.ColumnSpan="2" />

            <TextBlock x:Name="PasswordLabel" Grid.Row="2" Text="Password" VerticalAlignment="Center" />
            <PasswordBox x:Name="PasswordBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Height="28"
                         PasswordChanged="Credentials_Changed" VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>
        </Grid>

        <!-- Trust Server Certificate (always visible) -->
        <CheckBox x:Name="TrustServerCertificateCheckBox"
                  Grid.Row="5"
                  Content="Trust server certificate"
                  Margin="150,0,0,10"
                  IsChecked="True"
                  Checked="TrustCert_Changed"
                  Unchecked="TrustCert_Changed" />

        <!-- Preview -->
        <GroupBox x:Name="PreviewGroupBox" Grid.Row="6" Margin="0,0,0,14">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Preview" VerticalAlignment="Center" />
                </StackPanel>
            </GroupBox.Header>
            <TextBox x:Name="ConnectionStringPreviewTextBox"
                     Margin="8"
                     FontFamily="Consolas"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Test Connection"
                    Width="120"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="TestConnection_Click" />
            <Button Content="OK"
                    Width="80"
                    Height="30"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click" />
            <Button Content="Cancel"
                    Width="80"
                    Height="30"
                    IsCancel="True" />
        </StackPanel>
        <TextBlock x:Name="StatusMessage" HorizontalAlignment="Left" Margin="10,4,0,0" Grid.Row="7" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center" Width="263" Foreground="Gray" FontStyle="Italic"/>
    </Grid>
</Window>
